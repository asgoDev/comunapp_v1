# ==========================================
# EXCLUSIONES GLOBALES Y CACHÉ
# ==========================================
**/.DS_Store
**/thumbs.db
**/*.log

# ==========================================
# CONFIGURACIÓN PARA BACKEND (Node + Express)
# ==========================================
backend/node_modules/
backend/dist/
backend/build/
backend/.env
backend/.env.*
