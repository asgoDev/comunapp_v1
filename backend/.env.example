# === Servidor y Entorno ===
PORT=3000
NODE_ENV=production

# === Base de Datos ===
# Cadena de conexión a MongoDB Atlas
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/sigas?retryWrites=true&w=majority

# === JWT Secrets ===
# Llaves criptográficas de firma para tokens
JWT_ACCESS_SECRET=tu_secreto_para_access_token_aqui
JWT_REFRESH_SECRET=tu_secreto_para_refresh_token_aqui

# === CORS ===
# URL exacta del frontend en Vercel (sin barra diagonal / al final)
FRONTEND_URL=https://tu-app-frontend.vercel.app

# === Seed (Super Admin inicial) ===
SEED_NOMBRE=Admin
SEED_APELLIDO=Sistema
SEED_CEDULA=V-12345678
SEED_EMAIL=admin@sigas.gob.ve
SEED_PASSWORD=ContrasenaSegura123!
